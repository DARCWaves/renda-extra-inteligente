<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Conteúdos | Renda Extra Inteligente</title>

  <link rel="stylesheet" href="/style.css" />
</head>

<body>

  <header>
    <h1>🚀 Renda Extra Inteligente</h1>
    <nav>
      <a href="/">Home</a>
      <a href="/indicadores">Indicadores</a>
      <a href="/posts">Conteúdos</a>
      <a href="/categoria/renda-extra">Renda Extra</a>
      <a href="/categoria/investimentos">Investimentos</a>
    </nav>
  </header>

  <main>

    <section>
      <h2>📚 Conteúdos sobre Finanças</h2>
      <p>
        Aprenda sobre organização financeira, renda extra, investimentos,
        economia e decisões inteligentes para melhorar sua vida financeira.
      </p>
    </section>

    <!-- 🔥 LISTA DE POSTS -->
    <section>

      <% if (posts && Array.isArray(posts) && posts.length > 0) { %>

        <% posts.forEach(post => { %>

          <article style="margin-bottom: 20px; padding: 15px; border: 1px solid #333; border-radius: 10px;">

            <h3>
              <%= post.title || "Conteúdo sem título" %>
            </h3>

            <p>
              <%= post.description || post.seoDescription || "Conteúdo educativo sobre finanças." %>
            </p>

            <p>
              <strong>Categoria:</strong>
              <%= post.category || "financas" %>
            </p>

            <p style="font-size: 12px; color: #888;">
              Publicado em:
              <%= post.createdAt ? new Date(post.createdAt).toLocaleDateString("pt-BR") : "Data não disponível" %>
            </p>

            <a href="/post/<%= post.slug %>" style="display: inline-block; margin-top: 10px;">
              📖 Ler conteúdo completo
            </a>

          </article>

        <% }) %>

      <% } else { %>

        <!-- ❌ FALLBACK -->
        <article style="padding: 20px; border: 1px dashed #444; border-radius: 10px;">
          <h3>⚠ Nenhum conteúdo encontrado</h3>
          <p>
            Ainda não há conteúdos disponíveis no momento.
          </p>
        </article>

      <% } %>

    </section>

    <!-- 💰 BLOCO DE ANÚNCIO (ADSENSE FUTURO) -->
    <section style="margin: 30px 0; padding: 20px; border: 2px dashed #555; border-radius: 10px; text-align: center;">
      <p>🔹 Espaço reservado para anúncio (Google AdSense)</p>
    </section>

    <!-- 📊 CTA -->
    <section>
      <h3>📊 Continue explorando</h3>
      <p>
        Veja também os indicadores econômicos atualizados para entender melhor o cenário financeiro.
      </p>

      <a href="/indicadores">
        Ver indicadores econômicos →
      </a>
    </section>

  </main>

  <footer style="margin-top: 40px; padding: 20px; text-align: center; font-size: 12px; color: #aaa;">
    <p>© 2026 Renda Extra Inteligente</p>
  </footer>

</body>
</html>
