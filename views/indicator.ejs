<section class="indicator-hero">
  <p class="indicator-label">Indicador econômico</p>
  <h2><%= indicador.titulo %></h2>
  <p><%= indicador.seoDescription || indicador.explicacao %></p>
</section>

<section>
  <h3>📌 O que é?</h3>
  <p><%= indicador.explicacao %></p>
</section>

<section>
  <h3>⚠️ Impacto no seu bolso</h3>
  <p><%= indicador.impacto %></p>
</section>

<section>
  <h3>📊 Leitura visual</h3>

  <div class="chart-box">
    <canvas id="indicatorChart"></canvas>
  </div>

  <p class="chart-note">
    O gráfico abaixo é uma leitura educativa para facilitar a comparação do impacto desse indicador no dia a dia.
  </p>
</section>

<section>
  <h3>🧠 IA Financeira</h3>

  <% if (iaFinanceira) { %>
    <p><strong>Diagnóstico:</strong> <%= iaFinanceira.diagnostico || "Cenário em análise" %></p>

    <p>
      <%= iaFinanceira.analise || iaFinanceira.mensagem || iaFinanceira.explicacao || "A análise financeira ainda está sendo processada." %>
    </p>

    <% if (iaFinanceira.recomendacoes && iaFinanceira.recomendacoes.length) { %>
      <h4>Plano de ação</h4>
      <ul>
        <% iaFinanceira.recomendacoes.forEach(item => { %>
          <li><%= item %></li>
        <% }) %>
      </ul>
    <% } %>

    <% if (iaFinanceira.plano && iaFinanceira.plano.length) { %>
      <h4>Plano de ação</h4>
      <ul>
        <% iaFinanceira.plano.forEach(item => { %>
          <li><%= item %></li>
        <% }) %>
      </ul>
    <% } %>
  <% } else { %>
    <p>A IA financeira ainda não encontrou dados suficientes para este indicador.</p>
  <% } %>
</section>

<section>
  <h3>📘 Dicionário simples</h3>

  <div class="glossary-grid">
    <div class="glossary-item">
      <strong>Selic</strong>
      <p>Taxa básica de juros do Brasil. Ela influencia crédito, financiamento e investimentos.</p>
    </div>

    <div class="glossary-item">
      <strong>IPCA</strong>
      <p>Índice oficial da inflação no Brasil. Mostra quanto os preços subiram em média.</p>
    </div>

    <div class="glossary-item">
      <strong>PIS</strong>
      <p>Contribuição paga por empresas para financiar benefícios sociais, como abono salarial.</p>
    </div>

    <div class="glossary-item">
      <strong>Cofins</strong>
      <p>Contribuição sobre o faturamento das empresas. Pode aparecer embutida no preço final.</p>
    </div>

    <div class="glossary-item">
      <strong>INSS</strong>
      <p>Contribuição para Previdência Social, ligada a aposentadorias e benefícios.</p>
    </div>

    <div class="glossary-item">
      <strong>Poder de compra</strong>
      <p>Mostra o quanto seu dinheiro consegue comprar. Quando os preços sobem, ele cai.</p>
    </div>
  </div>
</section>

<section>
  <h3>🔗 Continue explorando</h3>

  <div class="related-grid">
    <a href="/indicadores">Ver todos os indicadores</a>
    <a href="/posts">Ler conteúdos financeiros</a>
    <a href="/categoria/renda-extra">Renda extra</a>
    <a href="/categoria/investimentos">Investimentos</a>
  </div>
</section>

<style>
.indicator-hero {
  text-align: center;
}

.indicator-label {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 999px;
  background: rgba(255,255,255,.12);
  color: #00ffcc;
  font-size: 13px;
  font-weight: bold;
}

.chart-box {
  background: rgba(255,255,255,.04);
  border-radius: 18px;
  padding: 14px;
  margin-top: 14px;
}

.chart-note {
  font-size: 14px;
  opacity: .8;
}

.glossary-grid,
.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 14px;
}

.glossary-item {
  background: rgba(255,255,255,.06);
  border-radius: 14px;
  padding: 14px;
}

.glossary-item strong {
  color: #00ffcc;
}

.related-grid a {
  display: block;
  padding: 12px 14px;
  border-radius: 14px;
  background: linear-gradient(135deg, #dffdf5, #ffffff);
  color: #001a1a;
  text-decoration: none;
  font-weight: bold;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const indicadorSlug = "<%= indicador.slug %>";

  const chartConfigs = {
    "dolar": {
      labels: ["Produtos nacionais", "Importados", "Combustíveis", "Eletrônicos"],
      values: [30, 35, 20, 15]
    },
    "selic": {
      labels: ["Crédito caro", "Renda fixa", "Consumo", "Empresas"],
      values: [35, 30, 20, 15]
    },
    "inflacao": {
      labels: ["Alimentação", "Transporte", "Habitação", "Outros"],
      values: [35, 25, 25, 15]
    },
    "bolso-popular": {
      labels: ["Comida", "Aluguel", "Transporte", "Energia/Gás", "Outros"],
      values: [32, 28, 18, 12, 10]
    },
    "salario-minimo": {
      labels: ["Gastos essenciais", "Transporte", "Impostos indiretos", "Livre"],
      values: [50, 15, 20, 15]
    },
    "tributos": {
      labels: ["Consumo", "Renda", "Empresas", "Importação"],
      values: [40, 25, 25, 10]
    }
  };

  const selected = chartConfigs[indicadorSlug] || {
    labels: ["Impacto direto", "Impacto indireto", "Outros"],
    values: [50, 30, 20]
  };

  new Chart(document.getElementById("indicatorChart"), {
    type: "doughnut",
    data: {
      labels: selected.labels,
      datasets: [{
        data: selected.values
      }]
    },
    options: {
      plugins: {
        tooltip: {
          callbacks: {
            label: function(context) {
              const value = context.raw;
              return context.label + ": " + value + "%";
            }
          }
        },
        legend: {
          labels: {
            color: "#ffffff"
          }
        }
      }
    }
  });
</script>
