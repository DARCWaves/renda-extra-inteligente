<section class="indicator-hero">
  <p class="indicator-label">Indicador econômico</p>

  <h2><%= indicador.titulo %></h2>

  <% if (indicador.valor) { %>
    <div class="indicator-value">
      <%= indicador.valor %>
    </div>
  <% } %>

  <% if (indicador.periodo) { %>
    <p class="indicator-period">
      <%= indicador.periodo %>
    </p>
  <% } %>

  <% if (indicador.valorOficial) { %>
    <p class="indicator-period">
      Oficial Banco Central: <%= indicador.valorOficial %>
    </p>
  <% } %>

  <p>
    <%= indicador.resumoCurto || indicador.seoDescription || indicador.explicacao %>
  </p>
</section>

<% if (adsenseClient && adsenseSlot) { %>
  <section class="ad-box">
    <ins class="adsbygoogle"
      style="display:block"
      data-ad-client="<%= adsenseClient %>"
      data-ad-slot="<%= adsenseSlot %>"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </section>
<% } %>

<section>
  <h3>📌 O que é?</h3>
  <p><%= indicador.explicacao %></p>
</section>

<% if (indicador.comoCalcula) { %>
  <section>
    <h3>🧮 Como é calculado?</h3>
    <p><%= indicador.comoCalcula %></p>
  </section>
<% } %>

<% if (adsenseClient && adsenseSlot) { %>
  <section class="ad-box">
    <ins class="adsbygoogle"
      style="display:block"
      data-ad-client="<%= adsenseClient %>"
      data-ad-slot="<%= adsenseSlot %>"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </section>
<% } %>

<% if (indicador.impactoBolso) { %>
  <section>
    <h3>⚠️ Impacto no seu bolso</h3>
    <p><%= indicador.impactoBolso %></p>
  </section>
<% } %>

<% if (indicador.impactoPais) { %>
  <section>
    <h3>🏛️ Impacto na economia do país</h3>
    <p><%= indicador.impactoPais %></p>
  </section>
<% } %>

<% if (indicador.tabela && indicador.tabela.length) { %>
  <section>
    <h3>📊 Tabela explicativa</h3>

    <div class="table-wrap">
      <table>
        <% indicador.tabela.forEach((row, index) => { %>
          <tr>
            <% row.forEach(cell => { %>
              <% if (index === 0) { %>
                <th><%= cell %></th>
              <% } else { %>
                <td><%= cell %></td>
              <% } %>
            <% }) %>
          </tr>
        <% }) %>
      </table>
    </div>
  </section>
<% } %>

<% if (indicador.chart) { %>
  <section>
    <h3>📈 Leitura visual</h3>

    <div class="chart-box">
      <canvas id="indicatorChart"></canvas>
    </div>

    <p class="chart-note">
      Este gráfico é uma leitura educativa para facilitar a comparação do impacto desse indicador.
    </p>
  </section>
<% } %>

<% if (iaFinanceira) { %>
  <section>
    <h3>🧠 IA Financeira</h3>

    <p>
      <strong>Diagnóstico:</strong>
      <%= iaFinanceira.diagnostico || "Cenário em análise" %>
    </p>

    <p>
      <%= iaFinanceira.analise || iaFinanceira.mensagem || iaFinanceira.explicacao || "A análise financeira ainda está sendo processada." %>
    </p>

    <% if (iaFinanceira.recomendacoes && iaFinanceira.recomendacoes.length) { %>
      <h4>Plano de ação</h4>
      <ul>
        <% iaFinanceira.recomendacoes.forEach(item => { %>
          <li><%= item %></li>
        <% }) %>
      </ul>
    <% } %>
  </section>
<% } %>

<% if (indicador.glossario && indicador.glossario.length) { %>
  <section>
    <h3>📘 Dicionário financeiro simples</h3>

    <div class="glossary-grid">
      <% indicador.glossario.forEach(item => { %>
        <div class="glossary-item">
          <strong><%= item.term %></strong>
          <p><%= item.meaning %></p>
        </div>
      <% }) %>
    </div>
  </section>
<% } %>

<% if (adsenseClient && adsenseSlot) { %>
  <section class="ad-box">
    <ins class="adsbygoogle"
      style="display:block"
      data-ad-client="<%= adsenseClient %>"
      data-ad-slot="<%= adsenseSlot %>"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </section>
<% } %>

<% if (indicador.relacionados && indicador.relacionados.length) { %>
  <section>
    <h3>🔗 Continue explorando</h3>

    <div class="related-grid">
      <% indicador.relacionados.forEach(item => { %>
        <a href="<%= item.url %>"><%= item.titulo %></a>
      <% }) %>
    </div>
  </section>
<% } %>

<style>
.indicator-hero {
  text-align: center;
}

.indicator-label {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 999px;
  background: rgba(255,255,255,.12);
  color: #00ffcc;
  font-size: 13px;
  font-weight: bold;
}

.indicator-value {
  margin: 18px auto 6px;
  font-size: 42px;
  font-weight: 900;
  color: #00ffcc;
  text-shadow: 0 0 18px rgba(0,255,204,.35);
}

.indicator-period {
  font-size: 14px;
  color: #cfd8dc;
  opacity: .85;
}

.ad-box {
  min-height: 90px;
  padding: 14px;
  border-radius: 16px;
  background: rgba(255,255,255,.04);
  border: 1px dashed rgba(255,255,255,.12);
}

.table-wrap {
  overflow-x: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 12px;
}

th, td {
  padding: 12px;
  border-bottom: 1px solid rgba(255,255,255,.12);
  text-align: left;
}

th {
  color: #00ffcc;
}

.chart-box {
  background: rgba(255,255,255,.04);
  border-radius: 18px;
  padding: 14px;
  margin-top: 14px;
}

.chart-note {
  font-size: 14px;
  opacity: .8;
}

.glossary-grid,
.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 14px;
}

.glossary-item {
  background: rgba(255,255,255,.06);
  border-radius: 14px;
  padding: 14px;
}

.glossary-item strong {
  color: #00ffcc;
}

.related-grid a {
  display: block;
  padding: 12px 14px;
  border-radius: 14px;
  background: linear-gradient(135deg, #dffdf5, #ffffff);
  color: #001a1a;
  text-decoration: none;
  font-weight: bold;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<% if (indicador.chart) { %>
<script>
  const chartData = <%- JSON.stringify(indicador.chart) %>;

  new Chart(document.getElementById("indicatorChart"), {
    type: chartData.type || "bar",
    data: {
      labels: chartData.labels,
      datasets: [{
        label: "Valor",
        data: chartData.values
      }]
    },
    options: {
      plugins: {
        tooltip: {
          callbacks: {
            label: function(context) {
              const value = context.raw;
              const suffix = chartData.suffix || "";
              return context.label + ": " + value + " " + suffix;
            }
          }
        },
        legend: {
          labels: {
            color: "#ffffff"
          }
        }
      }
    }
  });
</script>
<% } %>
